{
  "input_dim": 14,
  "num_classes": 14,
  "ft_dim": 256,
  "ft_depth": 8,
  "ft_heads": 8,
  "ft_attn_dropout": 0.1,
  "ft_ff_dropout": 0.1,
  "ft_ff_mult": 4,
  "ft_emb_dropout": 0.1,
  "ft_cls_dropout": 0.1,
  "loss": "focal",
  "focal_gamma": 2.0,
  "label_smoothing": 0.05,
  "use_weighted_sampler": false,
  "class_weight_power": 1.3,
  "auto_class_weights": true,
  "scheduler_type": "onecycle",
  "scheduler_patience": 3,
  "scheduler_factor": 0.5,
  "min_lr": 1e-06,
  "onecycle_pct_start": 0.1,
  "onecycle_div_factor": 25.0,
  "onecycle_final_div_factor": 10000.0,
  "use_ema": true,
  "ema_decay": 0.999,
  "early_stopping_patience": 10,
  "early_stopping_min_delta": 0.0001,
  "optimize_thresholds": true,
  "use_confusion_penalty": true,
  "confusion_penalty_alpha": 0.1,
  "confused_pairs": {
    "0-7": 1.5,
    "7-0": 1.5,
    "6-13": 1.2,
    "13-6": 1.2,
    "1-8": 1.0,
    "9-7": 0.8
  },
  "use_mixup": false,
  "mixup_alpha": 0.3,
  "mixup_target_classes": [],
  "threshold_small_class_limit": 150,
  "threshold_small_class_scale_max": 3.0,
  "stopped_epoch": 50
}